SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Optional (preferred for server-side chat/SQL tools):
# DATABASE_URL=postgresql://postgres.<project_ref>:<db_password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Needed for direct PostgreSQL operations fallback when DATABASE_URL is not set:
SUPABASE_DB_PASSWORD=your_database_password
# Optional overrides for fallback DB connection:
# SUPABASE_DB_HOST=db.<project_ref>.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
OPENAI_API_KEY=sk-...

# Fathom (Settings > API)
FATHOM_API_KEY=fth_...
FATHOM_TEAM_FILTER=Account Executives

# HubSpot (Settings > Integrations > Private Apps)
HUBSPOT_API_KEY=pat-...

# Optional
TRANSCRIPT_VIEW_NAME=v_transcripts
OPENAI_MODEL=gpt-4o-mini
BATCH_POLL_INTERVAL=60
MAX_TOKENS_PER_CHUNK=12000
PROMPT_VERSION=v2.0
